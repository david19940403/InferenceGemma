<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- ── Permisos de red ─────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- ── Energía ─────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Solicitar exención de optimización de batería (opcional pero recomendado) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- ── Foreground Service ──────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:targetApi="34" />

    <!-- ── Notificaciones (Android 13+) ────────────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Almacenamiento externo (para leer el modelo .bin) ───────────── -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- ── Hardware requerido: GPU ─────────────────────────────────────── -->
    <uses-feature android:name="android.hardware.opengles.aep" android:required="false" />
    <uses-feature android:glEsVersion="0x00030002" android:required="false" />
    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:extractNativeLibs="${extractNativeLibs}"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.InferenceLocal"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        tools:targetApi="31">
        <activity
            android:name="hn.fredi.inferencelocal.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.InferenceLocal">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <!-- ── LlmServerService (Foreground Service) ─────────────────── -->
        <!--
            foregroundServiceType="specialUse" es obligatorio en Android 14+
            para foreground services que no encajan en las categorías estándar.
            Documenta el uso en el formulario de revisión de Google Play.
        -->
        <service
            android:name="hn.fredi.inferencelocal.service.LlmServerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Local LLM inference server exposed via HTTP on the local network" />
        </service>
    </application>

</manifest>